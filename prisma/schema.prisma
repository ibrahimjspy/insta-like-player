// Prisma schema for Insta Like Player.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  INSTAGRAM
  TIKTOK
  FACEBOOK
}

/// A reel author. One creator has many liked reels (scoped per platform).
model Creator {
  id        String   @id @default(uuid())
  platform  Platform @default(INSTAGRAM)
  username  String
  reels     Reel[]
  createdAt DateTime @default(now())

  @@unique([platform, username])
}

/// A single liked reel. Starts as PENDING after import, becomes DOWNLOADED
/// once the sync worker has fetched the media via yt-dlp.
model Reel {
  id            String     @id @default(uuid())
  platform      Platform   @default(INSTAGRAM)
  shortcode     String
  reelUrl       String     @unique
  caption       String?
  creatorId     String?
  creator       Creator?   @relation(fields: [creatorId], references: [id])
  thumbnailPath String?
  videoPath     String?
  durationSec   Int?
  width         Int?
  height        Int?
  likedAt       DateTime?
  status        ReelStatus @default(PENDING)
  isFavorite    Boolean    @default(false)
  failReason    String?
  downloadedAt  DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  hashtags    Hashtag[]        @relation("ReelHashtags")
  collections CollectionReel[]
  history     WatchHistory[]
  engagement  ReelEngagement?

  @@unique([platform, shortcode])
  @@index([likedAt])
  @@index([status])
  @@index([isFavorite])
  @@index([platform])
}

/// A hashtag parsed from a reel caption. Many-to-many with reels.
model Hashtag {
  id    String @id @default(uuid())
  tag   String @unique
  reels Reel[] @relation("ReelHashtags")
}

/// A user-defined collection (e.g. "Funny", "Programming").
model Collection {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  reels       CollectionReel[]
}

/// Join table between collections and reels.
model CollectionReel {
  collectionId String
  reelId       String
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  reel       Reel       @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@id([collectionId, reelId])
}

/// Records playback so the reader can show history and resume position.
model WatchHistory {
  id          String   @id @default(uuid())
  reelId      String
  reel        Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  watchedAt   DateTime @default(now())
  positionSec Int      @default(0)

  @@index([watchedAt])
  @@index([reelId])
}

/// Per-reel engagement rollup for fast personalized feed scoring.
model ReelEngagement {
  reelId         String    @id
  reel           Reel      @relation(fields: [reelId], references: [id], onDelete: Cascade)
  watchCount     Int       @default(0)
  totalWatchSec  Int       @default(0)
  maxPositionSec Int       @default(0)
  loopCount      Int       @default(0)
  deepWatchCount Int       @default(0)
  quickSkipCount Int       @default(0)
  lastWatchedAt  DateTime?

  @@index([lastWatchedAt])
  @@index([totalWatchSec])
  @@index([deepWatchCount])
}

enum ReelStatus {
  PENDING
  DOWNLOADED
  FAILED
  UNAVAILABLE
  SKIPPED
}
