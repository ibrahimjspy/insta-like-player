# ─── Database ────────────────────────────────────────────────────────────────
# Matches the defaults in docker-compose.yml. Change credentials for production.
DATABASE_URL="postgresql://insta:insta@localhost:5432/insta_like_player?schema=public"

# Used by docker-compose to provision the Postgres container.
POSTGRES_USER=insta
POSTGRES_PASSWORD=insta
POSTGRES_DB=insta_like_player
POSTGRES_PORT=5432

# ─── Media storage ───────────────────────────────────────────────────────────
# Where downloaded reel videos and thumbnails are stored (gitignored).
MEDIA_DIR="./data/media"

# ─── Feed / reader behaviour ───────────────────────────────────────────────────
# How many reels are loaded per page in the infinite feed.
FEED_PAGE_SIZE=10

# ─── Sync worker (yt-dlp) ──────────────────────────────────────────────────────
# Path to the yt-dlp binary. Install with: brew install yt-dlp (macOS)
YTDLP_PATH=yt-dlp

# Optional: per-platform Netscape cookies.txt files (export from a logged-in browser).
# YTDLP_COOKIES_INSTAGRAM="./data/cookies-instagram.txt"
# YTDLP_COOKIES_TIKTOK="./data/cookies-tiktok.txt"
# YTDLP_COOKIES_FACEBOOK="./data/cookies-facebook.txt"
#
# Legacy alias — used as Instagram cookies when YTDLP_COOKIES_INSTAGRAM is unset.
# YTDLP_COOKIES_FILE="./data/cookies.txt"
#
# Browser impersonation (TLS fingerprint). TikTok returns 403s without it.
# Requires a yt-dlp built with curl_cffi, e.g.:
#   python3 -m venv ~/.ytdlp-venv
#   ~/.ytdlp-venv/bin/pip install -U "yt-dlp[default]" "curl_cffi>=0.11,<0.13"
#   YTDLP_PATH="$HOME/.ytdlp-venv/bin/yt-dlp"
# TikTok defaults to "chrome"; set blank to disable, or pick a target from
# `yt-dlp --list-impersonate-targets`.
# YTDLP_IMPERSONATE_TIKTOK=chrome
# YTDLP_IMPERSONATE_INSTAGRAM=
# YTDLP_IMPERSONATE_FACEBOOK=

# Minimum delay (ms) between downloads to stay polite to Instagram. Downloads
# run sequentially (one at a time); this controls the pace.
SYNC_RATE_LIMIT_MS=4000

# How many times to retry a failed download before marking it FAILED.
SYNC_MAX_RETRIES=3

# When true (default), sync only downloads sure-shot video URLs (/reel/, /tv/).
# Generic /p/ likes (often photos) are skipped. Set to false to try all likes.
# SYNC_REELS_ONLY=true
