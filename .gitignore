# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# downloaded media + platform exports + cookies (personal data — never commit)
/data
*.info.json
liked_posts.json
user_data_tiktok.json
posts_and_comments.json
cookies*.txt
facebook_collections.json

# raw screen recordings — only the exported docs/media/*.gif is committed
*.mov

# prisma generated client
/generated

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
